# EcoMeal Bot Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider: "lm_studio" or "huggingface"
LLM_PROVIDER=huggingface

# Hugging Face API Token (get from https://huggingface.co/settings/tokens)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# Model (Qwen3.5-0.8B recommended for speed/cost balance)
HF_MODEL=Qwen/Qwen3.5-0.8B
